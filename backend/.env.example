# Server
PORT=5000
NODE_ENV=production

# Firebase (get from Firebase Console > Project Settings > Your Apps)
FIREBASE_API_KEY=your_firebase_api_key
FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
FIREBASE_APP_ID=your_app_id

# Razorpay (get from Razorpay Dashboard > API Keys)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Gmail App Password (Gmail > Account > Security > App Passwords)
EMAIL_USER=your_gmail@gmail.com
EMAIL_PASS=your_gmail_app_password

# CORS — comma-separated list of allowed frontend origins
# e.g. https://your-app.vercel.app,https://www.yourdomain.com
ALLOWED_ORIGINS=https://your-app.vercel.app
